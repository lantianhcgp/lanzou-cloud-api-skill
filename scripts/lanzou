#!/bin/sh
# 蓝奏云 API CLI 包装脚本
# 用法: lanzou <命令> [参数...]

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PY_SCRIPT="$SCRIPT_DIR/lanzou_api.py"

if [ ! -f "$PY_SCRIPT" ]; then
    echo "错误: 找不到 $PY_SCRIPT" >&2
    exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
    echo "错误: 未找到 python3 命令" >&2
    exit 1
fi

exec python3 "$PY_SCRIPT" "$@"
